# 이 파일을 .env 로 복사해서 실제 값을 채운다. (.env는 git 제외)
TELEGRAM_BOT_TOKEN=봇파더에게_받은_토큰
ALLOWED_USER_IDS=내_텔레그램_유저_ID
# 서버(headless)에서만 필요 — 맥에서 `claude setup-token` 으로 발급
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# 코딩 모드 — 기본 켜짐(bypassPermissions). 대화 전용으로 바꾸려면 off 로 설정.
CLAUDE_PERMISSION_MODE=bypassPermissions
# 코딩 모드에서 명령 실행 전 취소 가능한 대기 시간(초). 0이면 즉시 실행.
CANCEL_DELAY=4
# 기본 모델. 비우면 구독 기본값(보통 sonnet). fable/opus/sonnet/haiku 또는 정확한 모델명.
# 채팅 중 /model 명령으로도 바꿀 수 있다.
CLAUDE_MODEL=
# 기본 사고 강도. 비우면 Claude 기본(high). low/medium/high/xhigh/max. /effort 로도 변경.
CLAUDE_EFFORT=
# 음성 메시지 → 텍스트 변환용 Groq 키 (console.groq.com 무료 발급). 없으면 음성 비활성.
GROQ_API_KEY=
